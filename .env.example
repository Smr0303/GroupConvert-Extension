# =============================================================================
# GroupMailBox Frontend (Plasmo Extension) - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# These are baked into the extension at BUILD TIME (not runtime).
# You MUST rebuild the extension after changing these values.
# =============================================================================

# Backend API URL
# For local development:
#   PLASMO_PUBLIC_BACKEND_URL=http://localhost:3000
# For production (replace with your actual backend domain):
#   PLASMO_PUBLIC_BACKEND_URL=https://your-backend-domain.com
PLASMO_PUBLIC_BACKEND_URL=http://localhost:3000
